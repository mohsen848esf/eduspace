# Copy to backend/.env and fill in real values for production.

# Django
SECRET_KEY=replace-with-a-50+-character-random-string
DEBUG=True

# Database (Postgres)
DB_NAME=eduspace
DB_USER=edu
DB_PASSWORD=edupass123
DB_HOST=localhost
DB_PORT=5432

# Channels / cache
REDIS_HOST=localhost

# LiveKit
# Local dev uses the docker-compose stack with the keys below. For production
# generate a strong api secret (>= 32 chars random) and rotate it periodically.
# When the Django process is on the host (not in docker), LIVEKIT_HOST_URL
# stays as http://localhost:7880. From inside docker-compose it would be
# http://livekit:7880.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_HOST_URL=http://localhost:7880
LIVEKIT_WS_URL=ws://localhost:7880

# Recording defaults
# 720p (default) | 1080p
RECORDING_DEFAULT_QUALITY=720p
# Where the egress worker writes MP4 files (mounted as /out in docker).
# Must match the bind mount in docker-compose.yml.
RECORDING_OUTPUT_DIR=media/recordings
# Hard upper bound for stored recordings per host (defense in depth).
RECORDING_MAX_DURATION_SECONDS=14400
