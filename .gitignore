# Ignore environment variables and database in backend
backend/.env
backend/db.sqlite3

# Ignore virtual environment and cache
backend/venv/
**/__pycache__/
**/*.pyc

# Ignore node_modules in frontend
frontend/node_modules/

# User-uploaded and generated media (recordings, avatars, etc.)
# We keep the directory structure via .gitkeep markers but ignore the files.
backend/media/*
!backend/media/.gitkeep
!backend/media/recordings/
backend/media/recordings/*
!backend/media/recordings/.gitkeep

# OS / editor noise
**/.DS_Store
**/Thumbs.db

# Local tooling caches and per-user editor metadata
.??*/specs/
.??*/steering/
.??*/hooks/
.??*/agents/

# Per-developer local overrides (editor preferences, machine-specific bits)
.editors.local
*.local