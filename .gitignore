# Ignore environment variables and database in backend
backend/.env
backend/db.sqlite3

# Ignore virtual environment and cache
backend/venv/
**/__pycache__/
**/*.pyc

# Ignore node_modules in frontend
frontend/node_modules/

# User-uploaded and generated media (recordings, avatars, etc.)
# We keep the directory structure via .gitkeep markers but ignore the files.
backend/media/*
!backend/media/.gitkeep
!backend/media/recordings/
backend/media/recordings/*
!backend/media/recordings/.gitkeep

# OS / editor noise
**/.DS_Store
**/Thumbs.db

# Local tooling caches and per-user editor metadata
.??*/specs/
.??*/steering/
.??*/hooks/
.??*/agents/

# Local-only files, documentation, and notes (never push these)
# Use .local in the filename (e.g., filename.local.md) or place them in a local/ directory
*.local.*
*_local.*
*.local
/local/
/docs/local/


# AI-context snapshots — manually regenerated, never committed.
ai-context.frontend.md
ai-context.backend.md
ai-context.project.md
ai-context.tasks.md
COMMIT_EDITMSG.txt
